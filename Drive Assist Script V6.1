if _G.AutoDriveAssist_Cleanup then
	pcall(_G.AutoDriveAssist_Cleanup)
end

local connections = {}
local function trackConnection(conn)
	table.insert(connections, conn)
	return conn
end

_G.AutoDriveAssist_Cleanup = function()
	for _, conn in ipairs(connections) do
		conn:Disconnect()
	end
	table.clear(connections)
	RunService:UnbindFromRenderStep("AutoDriveAssist_ApplyAngularVelocity")
	
	if Workspace:FindFirstChild("AutoDriveAssist_Visuals") then
		Workspace.AutoDriveAssist_Visuals:Destroy()
	end
	if player.PlayerGui:FindFirstChild("AutoDriveAssistGui") then
		player.PlayerGui.AutoDriveAssistGui:Destroy()
	end
end
