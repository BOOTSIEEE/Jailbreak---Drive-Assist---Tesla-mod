-- Cached raycast filter state. Rebuilt only on vehicle select, respawn, or
-- (debounced) actual structural changes to the vehicle - NOT every frame and
-- NOT on every single DescendantAdded/Removing signal fire. Building this
-- from GetDescendants() + a fresh RaycastParams on every such event was the
-- main source of the "gets laggier the longer I play" behavior: vehicle FX
-- (exhaust, skid marks, sounds) churn descendants constantly, so this could
-- fire many times a second and generate garbage nonstop.
local cachedRaycastParams = nil
local cachedIgnoreList = {}
local cachedThrustParts = {}
local ignoreListDirty = true
local timeSinceIgnoreListRebuild = math.huge
local IGNORE_LIST_REBUILD_INTERVAL = 0.5 -- seconds; debounce window for the expensive full rebuild
local vehicleWatchConnections = {}

local visualFolder = Instance.new("Folder")
