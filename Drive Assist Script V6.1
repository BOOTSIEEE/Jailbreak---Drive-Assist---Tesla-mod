local function horizontalDirection(vector)
	local flat = Vector3.new(vector.X, 0, vector.Z)
	if flat.Magnitude < 0.001 then return Vector3.new(0, 0, -1) end
	return flat.Unit
end

local function signedAngleY(fromDir, toDir)
	local cross = fromDir:Cross(toDir)
	local dot = fromDir:Dot(toDir)
	return math.atan2(cross.Y, dot)
end

local function findVehicle(instance)
	while instance and instance ~= Workspace do
		if instance:IsA("Model") and instance:FindFirstChild("Engine") then
			return instance
		end
		instance = instance.Parent
	end
	return nil
end

local function updateVehicleDimensions(vehicle)
	if not vehicle then return end
	local _, size = vehicle:GetBoundingBox()
	vehicleWidth = math.min(size.X, size.Z)
	vehicleLength = math.max(size.X, size.Z)
end

local function findSteeringController(vehicle)
	local engine = vehicle and vehicle:FindFirstChild("Engine")
	if not engine then return nil end
	local bav = engine:FindFirstChildOfClass("BodyAngularVelocity")
	if bav then
		bav.MaxTorque = Vector3.new(0, math.huge, 0)
	end
	return bav
end

-- Looks for a gear-shift RemoteEvent directly under the vehicle (matches the
-- "GearShiftRemote" seen in this vehicle's own drivetrain). If your vehicle kit
-- names it differently, or expects different arguments than a single boolean
-- (true = reverse), adjust the FireServer call inside updateThrottle below.
local function findGearShiftRemote(vehicle)
	return vehicle and vehicle:FindFirstChild("GearShiftRemote")
end

-- Disconnects the per-vehicle DescendantAdded/Removing watchers. Called both
-- when you pick a new vehicle (so watchers from the OLD vehicle don't keep
-- piling up) and from the master cleanup handler on script refresh. Also
-- removes these same Connection objects from the global `connections` list -
-- previously they were only cleared from vehicleWatchConnections, leaving 2
-- dead entries behind in `connections` on every single vehicle reselect.
local function disconnectVehicleWatchers()
	for _, conn in ipairs(vehicleWatchConnections) do
		conn:Disconnect()
		for i = #connections, 1, -1 do
			if connections[i] == conn then
				table.remove(connections, i)
				break
			end
		end
	end
	table.clear(vehicleWatchConnections)
end

-- Rebuilds the cached raycast ignore list + RaycastParams, AND the cached
-- thrust-part list used by applyAcceleration (folded into the same single
-- descendant pass so we're not walking GetDescendants() twice for the same
-- purpose). Only runs on vehicle select, character respawn, or a debounced
-- structural-change signal (see ignoreListDirty / IGNORE_LIST_REBUILD_INTERVAL
-- below) - NOT every frame, and NOT on every raw DescendantAdded event.
local function rebuildIgnoreList()
	local character = player.Character
	local list = { character, selectedVehicle }
	local thrustParts = {}

	if selectedVehicle then
		for _, child in ipairs(selectedVehicle:GetDescendants()) do
			if child:IsA("BasePart") then
				table.insert(list, child)
			end
			if child:IsA("VectorForce") and child.Parent and (child.Parent.Name == "Thrust" or string.find(child.Name, "Thrust")) then
				table.insert(thrustParts, { kind = "force", inst = child })
			elseif child:IsA("HingeConstraint") and child.ActuatorType == Enum.ActuatorType.Motor then
				table.insert(thrustParts, { kind = "motor", inst = child })
			end
		end
	end

	cachedIgnoreList = list
	cachedThrustParts = thrustParts

	if not cachedRaycastParams then
		cachedRaycastParams = RaycastParams.new()
		cachedRaycastParams.FilterType = Enum.RaycastFilterType.Exclude
		cachedRaycastParams.IgnoreWater = true
	end
	cachedRaycastParams.FilterDescendantsInstances = cachedIgnoreList
end

-- == SEVERITY / TURN-INTENSITY CURVE (color AND steering strength share one source of truth) ==
local SEVERITY_CURVE = {
	{ t = 0.00, color = CONFIG.Colors.Green,          turnMult = 0.22 },
	{ t = 0.15, color = Color3.fromRGB(160, 195, 60), turnMult = 0.32 }, -- yellow-green
	{ t = 0.30, color = CONFIG.Colors.Yellow,         turnMult = 0.46 },
	{ t = 0.45, color = Color3.fromRGB(255, 165, 0),  turnMult = 0.62 }, -- amber
	{ t = 0.60, color = CONFIG.Colors.Orange,         turnMult = 0.78 },
	{ t = 0.78, color = Color3.fromRGB(255, 65, 20),  turnMult = 0.92 }, -- orange-red
	{ t = 1.00, color = CONFIG.Colors.Red,            turnMult = 1.00 },
}

local function evaluateSeverity(urgencyFraction)
	urgencyFraction = math.clamp(urgencyFraction, 0, 1)
	for i = 1, #SEVERITY_CURVE - 1 do
		local a, b = SEVERITY_CURVE[i], SEVERITY_CURVE[i + 1]
		if urgencyFraction <= b.t then
			local span = b.t - a.t
			local localT = span > 0 and (urgencyFraction - a.t) / span or 0
			return a.color:Lerp(b.color, localT), a.turnMult + (b.turnMult - a.turnMult) * localT
		end
	end
	local last = SEVERITY_CURVE[#SEVERITY_CURVE]
	return last.color, last.turnMult
end

-- Uses the cached thrust-part list (built alongside the ignore list in
-- rebuildIgnoreList) instead of calling selectedVehicle:GetDescendants()
-- every single time throttle is applied (previously every Heartbeat that
-- touched throttle) - that was a second constant-allocation hotspot.
local function applyAcceleration(throttleMultiplier)
print("applyAcceleration called:", throttleMultiplier, "#thrustParts:", #cachedThrustParts)
	if not selectedVehicle then return end
	
	local seat = selectedVehicle:FindFirstChildOfClass("VehicleSeat", true)
	if seat then
		seat.ThrottleFloat = throttleMultiplier
	end

	for _, entry in ipairs(cachedThrustParts) do
		local desc = entry.inst
		if desc.Parent then -- guards against something destroyed since the cache was last built;
			                 -- the dirty-flag debounce will catch up and refresh shortly after
			if entry.kind == "force" then
				if not originalThrustForces[desc] then
					if desc.Force.Magnitude > 1000 then
						originalThrustForces[desc] = desc.Force
					else
						originalThrustForces[desc] = Vector3.new(0, 105000, 0)
					end
				end
				desc.Force = originalThrustForces[desc] * throttleMultiplier
			else
				desc.MotorMaxTorque = 50000
				desc.AngularVelocity = (CONFIG.TargetSpeed * 1.5) * throttleMultiplier
			end
		end
	end
end

-- Ramps the actual applied throttle toward a target instead of snapping to it -
-- real acceleration takes time, and slamming straight to full throttle/full reverse
-- is often what makes a "reverse" or "auto throttle" command look like it did nothing.
-- Also handles the forward/reverse gear flip: many vehicle kits (this one included,
-- given the GearShiftRemote) expect to be told when to shift gear rather than just
-- receiving a negative force - so we fire it once, edge-triggered, when direction
-- flips AND the vehicle has slowed down enough to shift like a real transmission.
local function updateThrottle(dt, targetThrottle, currentSpeed)
	targetThrottle = math.clamp(targetThrottle, -1, 1)
	local maxDelta = CONFIG.ThrottleRampRate * dt
	local delta = math.clamp(targetThrottle - currentThrottle, -maxDelta, maxDelta)
	currentThrottle += delta

	local wantsReverse = currentThrottle < -0.05
	if wantsReverse ~= lastGearReverse and currentSpeed < 6 then
		lastGearReverse = wantsReverse
		if gearShiftRemote then
			pcall(function()
				gearShiftRemote:FireServer(wantsReverse)
			end)
		end
	end

	applyAcceleration(currentThrottle)
end

local function drawRay(index, origin, endpoint, color)
	if not CONFIG.ShowVisuals then return end

	local part = rayParts[index]
	if not part then
		part = Instance.new("Part")
		part.Name = "SensorRay_" .. index
		part.Anchored = true
		part.CanCollide = false
		part.CanTouch = false
		part.CanQuery = false
		part.Material = Enum.Material.Neon
		part.Parent = visualFolder
		rayParts[index] = part
	end

	local length = math.max((endpoint - origin).Magnitude, 0.05)
	part.Size = Vector3.new(0.15, 0.15, length)
	part.CFrame = CFrame.lookAt(origin, endpoint) * CFrame.new(0, 0, -length / 2)
	part.Color = color
	part.Transparency = 0.15
end

local function drawPredictiveLine(index, startPos, endPos)
	if not CONFIG.ShowVisuals then return end

	local part = predictionParts[index]
	if not part then
		part = Instance.new("Part")
		part.Name = "PredictLine_" .. index
		part.Anchored = true
		part.CanCollide = false
		part.CanTouch = false
		part.CanQuery = false
		part.Material = Enum.Material.Neon
		part.Color = CONFIG.Colors.Blue -- Always clean Tesla Blue
		part.Parent = visualFolder
		predictionParts[index] = part
	end

	local length = math.max((endPos - startPos).Magnitude, 0.05)
	part.Size = Vector3.new(0.3, 0.3, length)
	part.CFrame = CFrame.lookAt(startPos, endPos) * CFrame.new(0, 0, -length / 2)
	part.Transparency = 0.15
end

local function drawWaypoint(index, pos, color, labelText)
	if not CONFIG.ShowVisuals or not pos then
		if waypointParts[index] then waypointParts[index]:Destroy() waypointParts[index] = nil end
		return
	end

	local part = waypointParts[index]
	if not part then
		part = Instance.new("Part")
		part.Name = "Waypoint_" .. index
		part.Shape = Enum.PartType.Ball
		part.Size = Vector3.new(2.5, 2.5, 2.5)
		part.Anchored = true
		part.CanCollide = false
		part.CanTouch = false
		part.CanQuery = false
		part.Material = Enum.Material.Neon
		part.Parent = visualFolder
		
		local bb = Instance.new("BillboardGui", part)
		bb.Size = UDim2.fromOffset(100, 25)
		bb.AlwaysOnTop = true
		bb.ExtentsOffset = Vector3.new(0, 2, 0)
		local lbl = Instance.new("TextLabel", bb)
		lbl.Size = UDim2.fromScale(1, 1)
		lbl.BackgroundTransparency = 1
		lbl.Font = Enum.Font.GothamBold
		lbl.TextSize = 11
		lbl.TextColor3 = Color3.new(1, 1, 1)
		lbl.TextStrokeTransparency = 0
		
		waypointParts[index] = part
	end

	part.Position = pos
	part.Color = color
	if part:FindFirstChildOfClass("BillboardGui") and part.BillboardGui:FindFirstChildOfClass("TextLabel") then
		part.BillboardGui.TextLabel.Text = labelText or ("P" .. index)
		part.BillboardGui.TextLabel.TextColor3 = color
	end
end

local function cleanUnusedVisuals()
	for i = CONFIG.RayCount + 1, #rayParts do
		if rayParts[i] then rayParts[i]:Destroy() rayParts[i] = nil end
	end
	for i = CONFIG.WaypointCount + 1, #waypointParts do
		if waypointParts[i] then waypointParts[i]:Destroy() waypointParts[i] = nil end
	end
end

local function clearPredictiveVisuals()
	for _, part in pairs(predictionParts) do part:Destroy() end
	table.clear(predictionParts)
end

local function clearVisuals()
	for _, part in pairs(rayParts) do part:Destroy() end
	for _, part in pairs(waypointParts) do part:Destroy() end
	clearPredictiveVisuals()
	table.clear(rayParts)
	table.clear(waypointParts)
end

local function resetAssistState()
	targetTurnRate = 0
	appliedTurnRate = 0
	currentUrgency = 0
	isAvoiding = false
	isRecovering = false
	recoveryHeading = nil
	wasControlling = false
	targetPosition = nil
	currentThrottle = 0
	smoothedSteerBias = 0
	applyAcceleration(0)
	clearVisuals()
	table.clear(originalThrustForces) -- drop refs to old vehicles' thrust parts, don't grow forever
end

