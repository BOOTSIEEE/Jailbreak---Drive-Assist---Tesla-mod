local function makeSlider(parent, labelText, minVal, maxVal, currentVal, isFloat, order, callback)
	local container = Instance.new("Frame")
	container.Size, container.BackgroundTransparency, container.LayoutOrder, container.Parent =
		UDim2.new(1, -10, 0, 45), 1, order, parent

	local label = Instance.new("TextLabel")
	label.Size, label.BackgroundTransparency = UDim2.new(1, 0, 0, 16), 1
	label.Font, label.TextSize, label.TextColor3 = Enum.Font.Gotham, 12, Color3.new(1, 1, 1)
	label.TextXAlignment, label.Text, label.Parent = Enum.TextXAlignment.Left, labelText .. ": " .. tostring(currentVal), container

	local track = Instance.new("Frame")
	track.Size, track.Position = UDim2.new(1, 0, 0, 8), UDim2.new(0, 0, 0, 24)
	track.BackgroundColor3, track.BorderSizePixel, track.Parent = Color3.fromRGB(40, 40, 45), 0, container
	Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

	local fill = Instance.new("Frame")
	local initialPct = (currentVal - minVal) / (maxVal - minVal)
	fill.Size = UDim2.new(math.clamp(initialPct, 0, 1), 0, 1, 0)
	fill.BackgroundColor3, fill.BorderSizePixel, fill.Parent = Color3.fromRGB(80, 140, 200), 0, track
	Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

	local knob = Instance.new("TextButton")
	knob.Size, knob.Position = UDim2.fromOffset(16, 16), UDim2.new(1, -8, 0.5, -8)
	knob.BackgroundColor3, knob.Text, knob.Parent = Color3.new(1, 1, 1), "", fill
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

	local dragging = false
	local function updateSlider(input)
		local relativeX = math.clamp(input.Position.X - track.AbsolutePosition.X, 0, track.AbsoluteSize.X)
		local pct = relativeX / track.AbsoluteSize.X
		local val = minVal + pct * (maxVal - minVal)
		if not isFloat then val = math.floor(val + 0.5) end
		fill.Size = UDim2.new(pct, 0, 1, 0)
		label.Text = string.format("%s: %s", labelText, isFloat and string.format("%.2f", val) or tostring(val))
		callback(val)
	end

	trackConnection(knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
	end))
	trackConnection(UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end))
	trackConnection(UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then updateSlider(input) end
	end))
	trackConnection(track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true updateSlider(input) end
	end))

	return container
end

