trackConnection(UserInputService.InputBegan:Connect(function(input, processed)
	if bindingKey and input.UserInputType == Enum.UserInputType.Keyboard then
		CONFIG.OverrideKey = input.KeyCode
		bindingKey = false
		refreshToggles()
		return
	end

	if input.KeyCode == Enum.KeyCode.RightShift then
		panel.Visible = not panel.Visible
		return
	end

	if input.KeyCode == CONFIG.OverrideKey then isOverriding = true end

	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		if pickingVehicle and mouse.Target then
			selectedVehicle = findVehicle(mouse.Target)
			if selectedVehicle then
				steeringController = findSteeringController(selectedVehicle)
				gearShiftRemote = findGearShiftRemote(selectedVehicle)
				updateVehicleDimensions(selectedVehicle)
				pickingVehicle = false
				selectButton.Text = string.format("Car: %s (W:%.1f)", selectedVehicle.Name, vehicleWidth)
				selectButton.BackgroundColor3 = Color3.fromRGB(62, 62, 70)
				status.Text = string.format("Calibrated! Width: %.1f studs. Ready to drive.", vehicleWidth)
				status.TextColor3 = CONFIG.Colors.Green

				table.clear(originalThrustForces)
				disconnectVehicleWatchers()
				table.insert(vehicleWatchConnections, trackConnection(
					selectedVehicle.DescendantAdded:Connect(function() ignoreListDirty = true end)
				))
				table.insert(vehicleWatchConnections, trackConnection(
					selectedVehicle.DescendantRemoving:Connect(function() ignoreListDirty = true end)
				))
				ignoreListDirty = false
				timeSinceIgnoreListRebuild = 0
				rebuildIgnoreList()
			end
		elseif CONFIG.AutoNavigate and mouse.Hit and not processed then
			targetPosition = mouse.Hit.Position
		end
	end
end))

trackConnection(UserInputService.InputEnded:Connect(function(input)
	if input.KeyCode == CONFIG.OverrideKey then isOverriding = false end
end))

-- == MAIN SENSOR & PREDICTION LOGIC ==
trackConnection(RunService.Heartbeat:Connect(function(heartbeatDt)
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")

	if not root or not selectedVehicle or not selectedVehicle.Parent then return end

	if not steeringController or not steeringController.Parent then
		steeringController = findSteeringController(selectedVehicle)
		if not steeringController then return end
	end

	local carPivot = selectedVehicle:GetPivot()
	local engine = selectedVehicle:FindFirstChild("Engine")
	local currentVelocity = engine and engine.AssemblyLinearVelocity or Vector3.zero
	local currentSpeed = currentVelocity.Magnitude

	local dynamicRayLength = CONFIG.RayLength + (currentSpeed * 0.8)
	local dynamicReactionDist = math.min(CONFIG.ReactionDistance + (currentSpeed * 0.6), dynamicRayLength * 0.85)

	local carPitchForward, carPitchRight, carPitchUp = carPivot.LookVector, carPivot.RightVector, carPivot.UpVector
	local origin = carPivot.Position + carPitchForward * CONFIG.OffsetZ + carPitchRight * CONFIG.OffsetX + carPitchUp * CONFIG.OffsetY

	timeSinceIgnoreListRebuild += heartbeatDt
	if not cachedRaycastParams then
		rebuildIgnoreList()
	elseif ignoreListDirty and timeSinceIgnoreListRebuild >= IGNORE_LIST_REBUILD_INTERVAL then
		rebuildIgnoreList()
		ignoreListDirty = false
		timeSinceIgnoreListRebuild = 0
	end
	local params = cachedRaycastParams

	local manualSteer = 0
	if UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.Left) then
		manualSteer = -1
	elseif UserInputService:IsKeyDown(Enum.KeyCode.D) or UserInputService:IsKeyDown(Enum.KeyCode.Right) then
		manualSteer = 1
	end

	local forwardMomentum = carPitchForward:Dot(currentVelocity)
	local isReversing = forwardMomentum < -2
	local moveDir = isReversing and -1 or 1

	-- adaptive ray geometry bias: prefers live manual input, else assist's own applied turn
	local rawSteerBias = 0
	if manualSteer ~= 0 then
		rawSteerBias = manualSteer
	elseif CONFIG.TurnRate > 0 then
		rawSteerBias = -math.clamp(appliedTurnRate / CONFIG.TurnRate, -1, 1)
	end
	smoothedSteerBias = smoothedSteerBias + (rawSteerBias - smoothedSteerBias) * math.clamp(heartbeatDt * CONFIG.RayAdaptSmoothing, 0, 1)
	local steerBias = smoothedSteerBias

	-- solid blue prediction line: flattened forward dir so pitch/bounce doesn't fake ground hits
	local predictionTime, curveSteps = 2.0, 10
	local timeStep = predictionTime / curveSteps

	local flatForward = horizontalDirection(carPitchForward)
	local predictedPoints = {origin}
	local simCFrame = CFrame.lookAt(origin, origin + (flatForward * moveDir))
	local simulatedTurnRate = manualSteer * CONFIG.TurnRate

	for step = 1, curveSteps do
		local stepDist = math.max(currentSpeed, 15) * timeStep
		local steerEffect = simulatedTurnRate * timeStep * moveDir
		simCFrame = simCFrame * CFrame.Angles(0, -steerEffect, 0)
		simCFrame = simCFrame + (simCFrame.LookVector * stepDist)
		table.insert(predictedPoints, simCFrame.Position)
	end

	local isIntentionalPathSafe = true
	local sweepRadius = math.max(vehicleWidth / 2, 1)

	for i = 1, #predictedPoints - 1 do
		local pStart, pEnd = predictedPoints[i], predictedPoints[i+1]
		local dir = pEnd - pStart
		local hit = Workspace:Spherecast(pStart, sweepRadius, dir.Unit * dir.Magnitude, params)
		if hit and hit.Normal:Dot(Vector3.yAxis) <= CONFIG.MaxGroundSlopeNormal then
			isIntentionalPathSafe = false
			drawPredictiveLine(i, pStart, hit.Position)
			for j = i + 1, curveSteps do if predictionParts[j] then predictionParts[j].Transparency = 1 end end
			break
		else
			drawPredictiveLine(i, pStart, pEnd)
		end
	end

	if not CONFIG.ShowVisuals then clearPredictiveVisuals() end

	-- fan sensor engine: distance + closing-rate + obstacle-width aware
	local bestDirection, bestDistance, repulsionNet, nearestThreat = carPitchForward, -math.huge, Vector3.zero, 0
	local greenCountLeft, totalLeft, greenCountRight, totalRight = 0, 0, 0, 0

	if not CONFIG.ShowVisuals then clearVisuals() else cleanUnusedVisuals() end

	-- pass 1: cast every ray, record raw geometry so pass 2 can tell a wide wall from a
	-- thin obstacle. Length/angle shift smoothly based on steerBias (see header note).
	local rayInfo = {}
	local halfSpread = math.max(CONFIG.SpreadDegrees / 2, 1)
	for i = 1, CONFIG.RayCount do
		local alpha = (CONFIG.RayCount == 1) and 0.5 or (i - 1) / (CONFIG.RayCount - 1)
		local baseAngle = -CONFIG.SpreadDegrees / 2 + CONFIG.SpreadDegrees * alpha
		local s = baseAngle / halfSpread

		local alignment = 1 - math.abs(s - steerBias) / 2
		local edgeShrink = 0.5 * math.abs(s) * (1 - math.abs(steerBias))
		local frontShrink = 0.6 * (1 - math.abs(s)) * math.abs(steerBias)
		local deviation = (2 * alignment - 1) - edgeShrink - frontShrink
		local lengthMult = math.clamp(1 + CONFIG.RayLengthVariance * deviation, 0.35, 1.75)

		local angleShift = CONFIG.RayAngleShift * (s * s * s) * (1 - math.abs(steerBias))
		local finalAngleDeg = baseAngle + angleShift

		-- angle negated so ray geometry matches left/right convention used elsewhere (v6.1 fix)
		local direction = (CFrame.fromAxisAngle(carPitchUp, math.rad(-finalAngleDeg)) * carPitchForward).Unit
		local rayMaxLength = dynamicRayLength * lengthMult

		local hit = Workspace:Raycast(origin, direction * rayMaxLength, params)
		local distance, hitObstacle = rayMaxLength, false

		if hit then
			if hit.Normal:Dot(Vector3.yAxis) > CONFIG.MaxGroundSlopeNormal then
				distance = rayMaxLength
			else
				distance, hitObstacle = (hit.Position - origin).Magnitude, true
			end
		end

		rayInfo[i] = { angle = finalAngleDeg, direction = direction, distance = distance, hitObstacle = hitObstacle }
	end

	-- pass 2: distance + closing-rate + obstacle-width -> threat urgency per ray, tallied
	-- green/not-green per side for the confidence vote (rays that hit nothing = zero threat)
	for i = 1, CONFIG.RayCount do
		local info = rayInfo[i]
		local distance, direction, angle = info.distance, info.direction, info.angle

		local neighborsClose = 0
		for offset = -2, 2 do
			if offset ~= 0 then
				local neighbor = rayInfo[i + offset]
				if neighbor and neighbor.hitObstacle and neighbor.distance < dynamicReactionDist * 1.15 then
					neighborsClose += 1
				end
			end
		end
		local widthFactor = math.clamp((neighborsClose + 1) / 5, 0.2, 1)

		local threatUrgency = 0
		if info.hitObstacle then
			local closingSpeed = currentVelocity:Dot(direction)
			local timeToImpact = closingSpeed > 0.5 and (distance / closingSpeed) or math.huge
			local closingUrgency = math.clamp(1 - (timeToImpact / CONFIG.ClosingRateWindow), 0, 1)
			local distUrgency = math.clamp(1 - (distance / dynamicReactionDist), 0, 1)
			threatUrgency = math.max(distUrgency, closingUrgency) * widthFactor
		end

		local elementColor = evaluateSeverity(threatUrgency)

		-- full driver authority: while actively steering, ray color reflects your input,
		-- not assist threat (committed side = green, opposite = red)
		if math.abs(manualSteer) > 0.1 then
			local turningLeft = manualSteer < 0
			local onLeftSide = angle < 0
			if turningLeft then
				elementColor = onLeftSide and CONFIG.Colors.Green or CONFIG.Colors.Red
			else
				elementColor = onLeftSide and CONFIG.Colors.Red or CONFIG.Colors.Green
			end
		end

		drawRay(i, origin, origin + direction * distance, elementColor)

		if angle < -10 then
			totalLeft += 1
			if threatUrgency < CONFIG.GreenThreshold then greenCountLeft += 1 end
		elseif angle > 10 then
			totalRight += 1
			if threatUrgency < CONFIG.GreenThreshold then greenCountRight += 1 end
		end

		if distance > bestDistance then bestDistance, bestDirection = distance, direction end
		nearestThreat = math.max(nearestThreat, threatUrgency)
		if threatUrgency > 0 then repulsionNet = repulsionNet - (direction * (threatUrgency * threatUrgency)) end
	end

	-- confidence-vote result: which side has the higher safe(green) fraction. side with
	-- no rays reads neutral (0.5), not a win.
	local safeFractionLeft = totalLeft > 0 and (greenCountLeft / totalLeft) or 0.5
	local safeFractionRight = totalRight > 0 and (greenCountRight / totalRight) or 0.5
	local decisionBias = safeFractionLeft - safeFractionRight
	local confidenceMargin = math.abs(decisionBias)

	if not CONFIG.Enabled or isOverriding then
		if isOverriding then
			status.Text, status.TextColor3 = "MANUAL OVERRIDE (Key Held)", Color3.fromRGB(200, 100, 255)
		else
			status.Text, status.TextColor3 = "Assist off.", Color3.fromRGB(190, 190, 190)
		end
		resetAssistState()
		return
	end

	local carForwardFlat = horizontalDirection(carPivot.LookVector)
	local urgency = nearestThreat
	currentUrgency = urgency

	-- zero-interference driver override: absolute priority
	if math.abs(manualSteer) > 0.1 then
		urgency, currentUrgency, repulsionNet, targetTurnRate = 0, 0, Vector3.zero, 0
		isAvoiding, isRecovering, recoveryHeading = false, false, nil

		if CONFIG.AssistAutoThrottle and currentThrottle ~= 0 then currentThrottle = 0 end

		if isIntentionalPathSafe then
			status.Text = isReversing and "MANUAL REVERSE: Path Clear" or "MANUAL TURN: Path Clear"
			status.TextColor3 = CONFIG.Colors.Blue
		else
			status.Text = "MANUAL OVERRIDE: WARNING! Path Obstructed!"
			status.TextColor3 = CONFIG.Colors.Red
		end
		return
	end

	-- == AUTO-NAVIGATE (dynamic bezier waypoints & cruise control) ==
	-- always full auto-throttle/brake/reverse regardless of the standard-assist auto-brake toggle
	if CONFIG.AutoNavigate then
		local speedError = (CONFIG.TargetSpeed - currentSpeed) / CONFIG.TargetSpeed
		local cruiseThrottle = math.clamp(speedError * 2.5, -0.5, 1.0)

		if urgency > CONFIG.EngageUrgency then
			cruiseThrottle = math.clamp(1 - (urgency * 2.2), -0.8, 0.3)
		end
		updateThrottle(heartbeatDt, cruiseThrottle, currentSpeed)

		if not targetPosition then
			local avoidTurn = 0
			if urgency > CONFIG.EngageUrgency and confidenceMargin >= CONFIG.DecisionConfidence then
				local decisiveness = math.clamp((confidenceMargin - CONFIG.DecisionConfidence) / (1 - CONFIG.DecisionConfidence), 0, 1)
				avoidTurn = (decisionBias > 0 and 1 or -1) * decisiveness
			end
			targetTurnRate = avoidTurn * CONFIG.TurnRate
			status.Text = string.format("AUTONOMOUS CRUISE (No GPS Target) | Spd: %.0f | Thr: %.1f", currentSpeed, currentThrottle)
			status.TextColor3 = CONFIG.Colors.Blue
			for w = 1, 5 do drawWaypoint(w, nil) end
			return
		end

		local distToTarget = (targetPosition - carPivot.Position).Magnitude
		if distToTarget < 18 then
			targetTurnRate, currentThrottle, targetPosition = 0, 0, nil
			applyAcceleration(0)
			status.Text, status.TextColor3 = "AUTO-NAVIGATE: Destination reached!", CONFIG.Colors.Green
			for w = 1, 5 do drawWaypoint(w, nil) end
			return
		end

		local p0 = carPivot.Position + (currentVelocity * 0.5)
		local p2 = targetPosition
		local toTargetDir = horizontalDirection(targetPosition - carPivot.Position)
		local p1 = carPivot.Position + (toTargetDir * math.min(distToTarget * 0.5, 45))

		if urgency > CONFIG.EngageUrgency then
			local bypassOffset = horizontalDirection(bestDirection + repulsionNet * 2.5) * (vehicleWidth * 3.0)
			p1 = carPivot.Position + (bestDirection * 35) + bypassOffset
		end

		local numWaypoints = math.clamp(CONFIG.WaypointCount, 1, 5)
		local firstWaypointPos = nil

		for w = 1, 5 do
			if w <= numWaypoints then
				local t = w / numWaypoints
				local wpPos = ((1 - t)^2 * p0) + (2 * (1 - t) * t * p1) + (t^2 * p2)
				if w == 1 then firstWaypointPos = wpPos end
				local label = (w == numWaypoints) and "Target (P" .. w .. ")" or ("Path P" .. w)
				local color = (w == 1) and CONFIG.Colors.Yellow or ((w == numWaypoints) and CONFIG.Colors.Purple or CONFIG.Colors.Blue)
				drawWaypoint(w, wpPos, color, label)
			else
				drawWaypoint(w, nil)
			end
		end

		if firstWaypointPos then
			local steerTargetDir = horizontalDirection(firstWaypointPos - carPivot.Position)
			local baseAngle = signedAngleY(carForwardFlat, steerTargetDir)
			targetTurnRate = math.abs(baseAngle) < math.rad(2.0) and 0
				or math.clamp(baseAngle / math.rad(35), -1, 1) * CONFIG.TurnRate
		end

		status.Text = string.format("NAVIGATING (%d Pts) | Spd: %.0f/%d | Thr: %.1f", numWaypoints, currentSpeed, CONFIG.TargetSpeed, currentThrottle)
		status.TextColor3 = urgency > CONFIG.EngageUrgency and CONFIG.Colors.Orange or CONFIG.Colors.Blue
		return
	end

	-- == MOUSE FOLLOW ==
	if CONFIG.MouseFollow then
		isAvoiding, isRecovering = false, false
		local hitPosition = mouse.Hit and mouse.Hit.Position
		if hitPosition then
			local toTarget = horizontalDirection(hitPosition - carPivot.Position)
			local angle = signedAngleY(carForwardFlat, toTarget)
			targetTurnRate = math.abs(angle) < math.rad(2) and 0
				or math.clamp(angle / math.rad(CONFIG.MouseFollowMaxAngleDegrees), -1, 1) * CONFIG.TurnRate
			if CONFIG.InvertSteering then targetTurnRate = -targetTurnRate end

			local dist = (hitPosition - carPivot.Position).Magnitude
			updateThrottle(heartbeatDt, dist > 20 and 0.8 or 0, currentSpeed)
		else
			targetTurnRate = 0
			updateThrottle(heartbeatDt, 0, currentSpeed)
		end
		currentUrgency = 1
		status.Text, status.TextColor3 = "FOLLOWING MOUSE", CONFIG.Colors.Yellow
		return
	end

	-- == STANDARD ASSIST (confidence-vote evasion, severity-scaled turn intensity) ==
	if urgency > CONFIG.EngageUrgency then
		if not isAvoiding then recoveryHeading, isAvoiding = carForwardFlat, true end
		isRecovering = false

		local severityColor, turnIntensity = evaluateSeverity(urgency)
		local confidencePct = math.floor(confidenceMargin * 100 + 0.5)

		if confidenceMargin >= CONFIG.DecisionConfidence then
			local decisiveness = math.clamp((confidenceMargin - CONFIG.DecisionConfidence) / (1 - CONFIG.DecisionConfidence), 0, 1)
			local turnSign = decisionBias > 0 and 1 or -1
			if CONFIG.InvertSteering then turnSign = -turnSign end
			targetTurnRate = turnSign * decisiveness * CONFIG.TurnRate * turnIntensity

			local sideText = (targetTurnRate > 0) and "LEFT" or "RIGHT"
			if CONFIG.AssistAutoThrottle then
				updateThrottle(heartbeatDt, math.clamp(1 - (urgency * 2.2), -0.8, 0.3), currentSpeed)
				status.Text = string.format("ASSIST - GUIDING %s (%d%% confident) + BRAKING", sideText, confidencePct)
			else
				status.Text = string.format("ASSIST - GUIDING %s (%d%% confident)", sideText, confidencePct)
			end
		else
			targetTurnRate = 0
			if CONFIG.AssistAutoThrottle then
				updateThrottle(heartbeatDt, math.clamp(1 - (urgency * 2.2), -0.8, 0.3), currentSpeed)
				status.Text = string.format("ASSIST - AMBIGUOUS (%d%%), HOLDING STRAIGHT + BRAKING", confidencePct)
			else
				status.Text = string.format("ASSIST - AMBIGUOUS (%d%%), HOLDING STRAIGHT", confidencePct)
			end
		end
		status.TextColor3 = severityColor
		return
	end

	if CONFIG.AssistAutoThrottle and currentThrottle ~= 0 then currentThrottle = 0 end

	if isAvoiding then isAvoiding, isRecovering = false, true end

	if isRecovering and recoveryHeading then
		local angle = signedAngleY(carForwardFlat, recoveryHeading)
		if math.abs(angle) <= math.rad(CONFIG.RecoveryToleranceDegrees) then
			isRecovering, recoveryHeading, targetTurnRate = false, nil, 0
			status.Text, status.TextColor3 = "CLEAR - straight priority locked", CONFIG.Colors.Green
		else
			local turnStrength = math.clamp(angle / math.rad(CONFIG.RecoveryMaxAngleDegrees), -1, 1)
			targetTurnRate = (CONFIG.InvertSteering and -turnStrength or turnStrength) * (CONFIG.TurnRate * 0.75)
			status.Text, status.TextColor3 = "CORRECTING HEADING", CONFIG.Colors.Orange
		end
		return
	end

	targetTurnRate = 0
	status.Text, status.TextColor3 = "CLEAR - straight priority (manual active)", CONFIG.Colors.Green
end))

RunService:BindToRenderStep("AutoDriveAssist_ApplyAngularVelocity", Enum.RenderPriority.Last.Value, function(dt)
	if not steeringController or not steeringController.Parent then return end

	local manualSteer = 0
	if UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.Left) or
	   UserInputService:IsKeyDown(Enum.KeyCode.D) or UserInputService:IsKeyDown(Enum.KeyCode.Right) then
		manualSteer = 1
	end

	if manualSteer == 1 or isOverriding or not CONFIG.Enabled or not selectedVehicle then
		if wasControlling then
			appliedTurnRate, wasControlling = 0, false
			steeringController.AngularVelocity = Vector3.zero
		end
		return
	end

	local active = CONFIG.MouseFollow or CONFIG.AutoNavigate or (currentUrgency > CONFIG.EngageUrgency) or isRecovering

	if active then
		local urgencyBoost = 1 + (currentUrgency * 3)
		local responsiveness = CONFIG.TurnSmoothing * urgencyBoost
		appliedTurnRate += (targetTurnRate - appliedTurnRate) * math.clamp(dt * responsiveness, 0, 1)
		steeringController.AngularVelocity = Vector3.new(0, appliedTurnRate, 0)
		wasControlling = true
	elseif wasControlling then
		appliedTurnRate, wasControlling = 0, false
		steeringController.AngularVelocity = Vector3.zero
	end
end)

