local function refreshToggles()
	toggleButton.Text = CONFIG.Enabled and "Assist: ON" or "Assist: OFF"
	toggleButton.BackgroundColor3 = CONFIG.Enabled and Color3.fromRGB(40, 135, 78) or Color3.fromRGB(120, 53, 53)
	mouseFollowButton.Text = CONFIG.MouseFollow and "Mouse Follow: ON" or "Mouse Follow: OFF"
	mouseFollowButton.BackgroundColor3 = CONFIG.MouseFollow and Color3.fromRGB(150, 110, 40) or Color3.fromRGB(62, 62, 70)
	autoNavigateButton.Text = CONFIG.AutoNavigate and "Auto-Navigate: ON" or "Auto-Navigate (Cruise & Waypoints): OFF"
	autoNavigateButton.BackgroundColor3 = CONFIG.AutoNavigate and Color3.fromRGB(110, 40, 150) or Color3.fromRGB(62, 62, 70)
	debugVisualsButton.Text = CONFIG.ShowVisuals and "Debug Visuals: ON" or "Debug Visuals: OFF"
	debugVisualsButton.BackgroundColor3 = CONFIG.ShowVisuals and Color3.fromRGB(80, 80, 90) or Color3.fromRGB(62, 62, 70)
	keybindButton.Text = bindingKey and "Press any key..." or "Hold-Override Key: " .. CONFIG.OverrideKey.Name
	assistThrottleButton.Text = CONFIG.AssistAutoThrottle and "Standard Assist Auto-Brake: ON" or "Standard Assist Auto-Brake: OFF"
	assistThrottleButton.BackgroundColor3 = CONFIG.AssistAutoThrottle and Color3.fromRGB(150, 60, 60) or Color3.fromRGB(62, 62, 70)
end

